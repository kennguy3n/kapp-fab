DB_URL=postgres://kapp:kapp_dev@localhost:5432/kapp?sslmode=disable
LISTEN_ADDR=:8080

# S3-compatible object store (leave S3_BUCKET blank to use in-memory store)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=kapp-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

NATS_URL=nats://localhost:4222

# Phase H JWT auth. KAPP_JWT_SECRET must be >= 32 bytes.
#
# As of Phase 1 (security hardening) every tenant-scoped route group
# (records, finance, agents, helpdesk, inventory, forms, ... and
# /api/v1/tenants/me) sits behind tenantChain, which requires a
# configured signer. Leaving KAPP_JWT_SECRET empty no longer falls back
# to the X-Tenant-ID header path — every tenant-scoped request will
# instead get a 503 with "tenant routes require JWT auth; set
# KAPP_JWT_SECRET" so a misconfigured deployment fails loudly instead
# of silently re-exposing the header-injection vector the X-User-ID
# removal closed.
#
# The placeholder below is a 66-character ASCII string intended ONLY
# for `make dev` / docker-compose on localhost so the API boots
# without manual setup. It exceeds the 32-byte minimum that
# auth.NewSigner enforces, but it is NOT a high-entropy random
# secret — a literal string is easy to recognise as a dev
# placeholder when it shows up in logs. For staging or production
# it MUST be rotated to a freshly generated value (e.g.
# `openssl rand -base64 48` produces a 64-char base64 string with
# 384 bits of entropy) and managed via your secret store. Reusing
# this dev value outside of localhost defeats the JWT signing
# guarantee — anyone with a copy of .env.example can mint admin-
# looking tokens.
#
# Defence in depth: services/api/auth.go::newAuthSigner refuses to
# construct a signer keyed on this exact literal unless
# KAPP_ALLOW_DEV_JWT_SECRET=1 is also set (see below). A deployment
# that copies .env.example without rotating the secret will fail
# to start instead of silently signing tokens with the well-known
# placeholder key. The opt-in flag is set explicitly here so the
# dev compose stack continues to boot.
KAPP_JWT_SECRET=dev-only-kapp-jwt-secret-do-not-use-outside-localhost-fLPXuVqo9wKn
KAPP_ALLOW_DEV_JWT_SECRET=1
KAPP_JWT_ACCESS_TTL=15m
KAPP_JWT_REFRESH_TTL=24h
KAPP_JWT_ISSUER=kapp
KAPP_JWT_AUDIENCE=kapp

# PR-6: Secret-provider abstraction + JWT keyring rotation.
#
# KAPP_SECRET_PROVIDER selects the backend the API resolves JWT
# (and future) secrets through:
#   ""      / "env"   — os.Getenv(KAPP_*); pre-PR-6 behaviour
#                       (default). Keep this in local dev so the
#                       existing KAPP_JWT_SECRET path stays live.
#   "file"            — on-disk root, files named after the secret
#                       key (KAPP_SECRETS_FILE_ROOT_DIR). Suitable
#                       for K8s Secret volume mounts.
#   "aws"             — AWS Secrets Manager (KAPP_SECRETS_AWS_REGION,
#                       KAPP_SECRETS_AWS_PREFIX).
#   "vault"           — HashiCorp Vault KV v2 over HTTP
#                       (KAPP_SECRETS_VAULT_ADDR,
#                       KAPP_SECRETS_VAULT_TOKEN, MOUNT_PATH).
#   "gcp"             — stub; explicit ErrProviderNotConfigured
#                       so a typo doesn't silently fail open.
#
# JWT keys are fetched via PrimaryRef (the secret key the active
# signer reads from) + optional VerifyRefs (the previously-active
# keys kept in the ring during rotation so in-flight tokens keep
# verifying). Algorithm selects HS256 (default) or RS256. The
# refresher polls the provider every KAPP_JWT_KEYRING_REFRESH_INTERVAL
# and atomically swaps the primary key when the upstream version
# changes — no restart needed.
# KAPP_SECRET_PROVIDER=
# KAPP_SECRETS_ENV_PREFIX=KAPP_
# KAPP_SECRETS_FILE_ROOT_DIR=/var/run/kapp/secrets
# KAPP_SECRETS_AWS_REGION=us-east-1
# KAPP_SECRETS_AWS_PREFIX=kapp/
# KAPP_SECRETS_AWS_ENDPOINT=
# KAPP_SECRETS_VAULT_ADDR=https://vault.example.com
# KAPP_SECRETS_VAULT_TOKEN=
# KAPP_SECRETS_VAULT_MOUNT_PATH=secret
# KAPP_SECRETS_VAULT_SECRET_KEY=value
# KAPP_SECRETS_GCP_PROJECT_ID=my-gcp-project
# KAPP_SECRETS_GCP_PREFIX=kapp-
# KAPP_SECRETS_GCP_VERSION=latest
# KAPP_JWT_PRIMARY_REF=jwt/primary
# KAPP_JWT_VERIFY_REFS=jwt/previous,jwt/older
# KAPP_JWT_ALGORITHM=HS256
# KAPP_JWT_LEEWAY=30s
# KAPP_JWT_KEYRING_REFRESH_INTERVAL=60s

# Authorization enforcement. ENABLED by default. Set to 0 or false
# ONLY for local dev against pre-JWT clients; logs a WARN at startup
# and must never be flipped in staging or production.
# KAPP_AUTHZ_ENFORCE=1

# Phase 5: JWT enforcement on the importer + agent-tools sidecars.
# When unset (default), the sidecars fall back to the legacy
# X-Tenant-ID header path with a loud WARN log — useful only for
# clusters that haven't yet rolled out JWT to their sidecars and
# only on a fully trusted internal network. Set to 1 (or true) in
# staging / production so a missing or invalid KAPP_JWT_SECRET
# fails the boot loudly instead of silently re-exposing the
# header-impersonation hole that Phase 1 closed on services/api.
# Mirrors KAPP_REQUIRE_REDIS in spirit.
# KAPP_REQUIRE_JWT=1

# Phase 5: HTTP/2 timeout policy for every Kapp HTTP server (api,
# worker, importer, agent-tools, kchat-bridge). All five timeouts
# default to a safe production policy; the env vars below are only
# needed when a workload legitimately requires a different value
# (e.g. importer accepting 200-MiB CSVs would bump
# KAPP_HTTP_READ_TIMEOUT). The full policy lives in
# internal/platform/httptimeouts.go.
# KAPP_HTTP_READ_HEADER_TIMEOUT=10s
# KAPP_HTTP_READ_TIMEOUT=60s
# KAPP_HTTP_WRITE_TIMEOUT=120s
# KAPP_HTTP_IDLE_TIMEOUT=120s
# KAPP_HTTP_MAX_HEADER_BYTES=1048576

# Phase 6A: dedicated /api/v1/events/stream listener.
#
# When unset, the main API server (LISTEN_ADDR) carries the SSE
# stream alongside every other route, which forces WriteTimeout=0
# on the whole listener — the SSE handler holds the response open
# for the lifetime of the subscription and a non-zero WriteTimeout
# would terminate every stream at most that many seconds after
# headers were written. Setting WriteTimeout=0 in turn widens the
# slow-write surface across every non-streaming route.
#
# When set, the SSE handler is split off to a dedicated
# http.Server on the supplied host:port (LongStreamTimeouts,
# Write=0) and the main API listener adopts DefaultHTTPTimeouts
# (Write=120s) so every other route gets the strict slow-write
# defense too. Recommended for staging / production; the SSE port
# should sit behind the same internal network policy as
# KAPP_METRICS_ADDR.
# KAPP_SSE_ADDR=:8081
#
# When the SSE listener is split out via KAPP_SSE_ADDR, its HTTP
# timeouts are tuned independently of the main API listener via
# the KAPP_SSE_* env namespace below. The KAPP_HTTP_* knobs below
# only apply to the main API listener and DO NOT bleed into the
# SSE listener (so raising KAPP_HTTP_WRITE_TIMEOUT for the main
# API server cannot accidentally terminate SSE subscriptions).
# KAPP_SSE_READ_HEADER_TIMEOUT=10s
# KAPP_SSE_READ_TIMEOUT=60s
# KAPP_SSE_WRITE_TIMEOUT=0s    # default 0 (unlimited) — REQUIRED for SSE
# KAPP_SSE_IDLE_TIMEOUT=120s
# KAPP_SSE_MAX_HEADER_BYTES=1048576

# Phase 4: dedicated /metrics listener. When unset, /metrics is
# mounted on the main router (legacy single-port mode). When set,
# a dedicated http.Server listens on the supplied address so
# Prometheus scrapes don't contend with user-facing latency and
# stay off the auth chain. Production deployments SHOULD set this
# to a separate port behind an internal-only network policy.
# KAPP_METRICS_ADDR=:9090
#
# The metrics listener uses its own KAPP_METRICS_* env namespace so
# the user-facing KAPP_HTTP_* knobs (which tune the main API
# listener) cannot inadvertently widen the metrics scrape timeouts
# and increase scraper-induced backpressure. Defaults are tighter
# than the user-facing listener (ReadHeader=5s, Read=10s, Write=30s,
# Idle=60s, MaxHeaderBytes=64 KiB).
# KAPP_METRICS_READ_HEADER_TIMEOUT=5s
# KAPP_METRICS_READ_TIMEOUT=10s
# KAPP_METRICS_WRITE_TIMEOUT=30s
# KAPP_METRICS_IDLE_TIMEOUT=60s
# KAPP_METRICS_MAX_HEADER_BYTES=65536

# Phase 6C: OpenTelemetry tracing.
#
# KAPP_OTEL_ENDPOINT is the OTLP/gRPC collector endpoint as
# host:port (no scheme — gRPC adds its own framing). When unset
# (default), every service installs a no-op TracerProvider and
# spans are NOT exported anywhere — handlers can still call
# otel.Tracer(...).Start(...) but the hot path is a nil-check
# and zero wire cost. Set this to point at a Tempo / Jaeger /
# Datadog collector when distributed tracing is required.
# KAPP_OTEL_ENDPOINT=localhost:4317
#
# KAPP_OTEL_INSECURE controls whether the gRPC client uses TLS.
# Defaults to 1 (true) so local docker-compose Tempo works
# without certs. Production deployments MUST set this to 0 and
# terminate TLS at the collector.
# KAPP_OTEL_INSECURE=0
#
# KAPP_OTEL_SAMPLE_RATIO is the head-based sampling ratio in
# [0.0, 1.0] applied to root spans. Inherited (non-root) spans
# honour their parent's decision via ParentBased so a sampled
# trace is not chopped mid-flight. Default 0.1 (10%). Set to 1.0
# for pre-production debugging; 0.0 still receives sampled
# parent contexts but never emits a root span on its own.
# KAPP_OTEL_SAMPLE_RATIO=0.1
#
# KAPP_OTEL_SERVICE_VERSION is an optional version tag attached
# to every span via the semconv `service.version` resource
# attribute. Empty is acceptable; a future release pipeline
# injecting a git tag at build time will fill this in.
# KAPP_OTEL_SERVICE_VERSION=v0.1.0

# Platform-admin bootstrap list. Comma-separated *KChat user IDs*
# (the opaque SSO-provider-issued identifier from KChat — NOT Kapp
# internal UUIDs) that should be promoted to platform admins on
# their next SSO login. Required for fresh installs that have no
# platform admins in the users table yet. Once at least one user
# has is_platform_admin=TRUE in the DB this env var can be retired
# — the flag persists across logins.
#
# Why KChat IDs and not Kapp UUIDs: the operator can read a KChat
# ID from KChat itself BEFORE the user has ever signed in to Kapp.
# The Kapp internal UUID is generated by uuid.New() at the moment
# the row is inserted in users, so keying the bootstrap on it
# would force a two-step workflow (first SSO creates the row,
# operator looks up the new UUID, sets the env var, user logs in
# again) and would skip the "first login" promotion path entirely.
# See internal/auth/sso.go::bootstrapAdmin and
# migrations/000051_users_platform_admin.sql for the full
# rationale.
KAPP_PLATFORM_ADMIN_USERS=

# KChat SSO. Endpoints are documented in internal/auth/sso.go.
KCHAT_BASE_URL=
KCHAT_API_KEY=

# Per-tenant field-level encryption master keys. Supply a >= 32-byte
# secret or a base64 blob; KAPP_MASTER_KEY_PREV is the retiring key
# used only by DecryptString during rotation.
KAPP_MASTER_KEY=
KAPP_MASTER_KEY_PREV=

# SMTP transport for outbound notification emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=kapp@example.com

# ZK Object Fabric — multi-tenant zero-knowledge S3-compatible
# storage gateway. When ZK_FABRIC_ENDPOINT is set, tenants whose
# tenants.zk_access_key / zk_secret_key / zk_bucket columns are
# populated upload through the per-tenant ZK fabric bucket;
# tenants without those columns fall back to the global S3_BUCKET
# above. Leave ZK_FABRIC_ENDPOINT blank to disable the integration
# entirely (legacy MinIO path).
ZK_FABRIC_ENDPOINT=
ZK_FABRIC_REGION=us-east-1
# ZK fabric console (admin) endpoint at port 8081. The setup wizard
# calls it during tenant provisioning to mint per-tenant HMAC keys
# and create the per-tenant bucket. Leave blank to skip provisioning
# (legacy MinIO path stays in place).
ZK_FABRIC_CONSOLE_ENDPOINT=
ZK_FABRIC_ADMIN_TOKEN=
# Bucket name template; supports {slug} and {tenant_id}.
ZK_FABRIC_BUCKET_TEMPLATE=kapp-{slug}
