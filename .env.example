DB_URL=postgres://kapp:kapp_dev@localhost:5432/kapp?sslmode=disable
LISTEN_ADDR=:8080

# S3-compatible object store (leave S3_BUCKET blank to use in-memory store)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=kapp-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

NATS_URL=nats://localhost:4222

# Phase H JWT auth. KAPP_JWT_SECRET must be >= 32 bytes.
#
# As of Phase 1 (security hardening) every tenant-scoped route group
# (records, finance, agents, helpdesk, inventory, forms, ... and
# /api/v1/tenants/me) sits behind tenantChain, which requires a
# configured signer. Leaving KAPP_JWT_SECRET empty no longer falls back
# to the X-Tenant-ID header path — every tenant-scoped request will
# instead get a 503 with "tenant routes require JWT auth; set
# KAPP_JWT_SECRET" so a misconfigured deployment fails loudly instead
# of silently re-exposing the header-injection vector the X-User-ID
# removal closed.
#
# The placeholder below is a 66-character ASCII string intended ONLY
# for `make dev` / docker-compose on localhost so the API boots
# without manual setup. It exceeds the 32-byte minimum that
# auth.NewSigner enforces, but it is NOT a high-entropy random
# secret — a literal string is easy to recognise as a dev
# placeholder when it shows up in logs. For staging or production
# it MUST be rotated to a freshly generated value (e.g.
# `openssl rand -base64 48` produces a 64-char base64 string with
# 384 bits of entropy) and managed via your secret store. Reusing
# this dev value outside of localhost defeats the JWT signing
# guarantee — anyone with a copy of .env.example can mint admin-
# looking tokens.
#
# Defence in depth: services/api/auth.go::newAuthSigner refuses to
# construct a signer keyed on this exact literal unless
# KAPP_ALLOW_DEV_JWT_SECRET=1 is also set (see below). A deployment
# that copies .env.example without rotating the secret will fail
# to start instead of silently signing tokens with the well-known
# placeholder key. The opt-in flag is set explicitly here so the
# dev compose stack continues to boot.
KAPP_JWT_SECRET=dev-only-kapp-jwt-secret-do-not-use-outside-localhost-fLPXuVqo9wKn
KAPP_ALLOW_DEV_JWT_SECRET=1
KAPP_JWT_ACCESS_TTL=15m
KAPP_JWT_REFRESH_TTL=24h
KAPP_JWT_ISSUER=kapp
KAPP_JWT_AUDIENCE=kapp

# Authorization enforcement. ENABLED by default. Set to 0 or false
# ONLY for local dev against pre-JWT clients; logs a WARN at startup
# and must never be flipped in staging or production.
# KAPP_AUTHZ_ENFORCE=1

# Platform-admin bootstrap list. Comma-separated *KChat user IDs*
# (the opaque SSO-provider-issued identifier from KChat — NOT Kapp
# internal UUIDs) that should be promoted to platform admins on
# their next SSO login. Required for fresh installs that have no
# platform admins in the users table yet. Once at least one user
# has is_platform_admin=TRUE in the DB this env var can be retired
# — the flag persists across logins.
#
# Why KChat IDs and not Kapp UUIDs: the operator can read a KChat
# ID from KChat itself BEFORE the user has ever signed in to Kapp.
# The Kapp internal UUID is generated by uuid.New() at the moment
# the row is inserted in users, so keying the bootstrap on it
# would force a two-step workflow (first SSO creates the row,
# operator looks up the new UUID, sets the env var, user logs in
# again) and would skip the "first login" promotion path entirely.
# See internal/auth/sso.go::bootstrapAdmin and
# migrations/000051_users_platform_admin.sql for the full
# rationale.
KAPP_PLATFORM_ADMIN_USERS=

# KChat SSO. Endpoints are documented in internal/auth/sso.go.
KCHAT_BASE_URL=
KCHAT_API_KEY=

# Per-tenant field-level encryption master keys. Supply a >= 32-byte
# secret or a base64 blob; KAPP_MASTER_KEY_PREV is the retiring key
# used only by DecryptString during rotation.
KAPP_MASTER_KEY=
KAPP_MASTER_KEY_PREV=

# SMTP transport for outbound notification emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=kapp@example.com

# ZK Object Fabric — multi-tenant zero-knowledge S3-compatible
# storage gateway. When ZK_FABRIC_ENDPOINT is set, tenants whose
# tenants.zk_access_key / zk_secret_key / zk_bucket columns are
# populated upload through the per-tenant ZK fabric bucket;
# tenants without those columns fall back to the global S3_BUCKET
# above. Leave ZK_FABRIC_ENDPOINT blank to disable the integration
# entirely (legacy MinIO path).
ZK_FABRIC_ENDPOINT=
ZK_FABRIC_REGION=us-east-1
# ZK fabric console (admin) endpoint at port 8081. The setup wizard
# calls it during tenant provisioning to mint per-tenant HMAC keys
# and create the per-tenant bucket. Leave blank to skip provisioning
# (legacy MinIO path stays in place).
ZK_FABRIC_CONSOLE_ENDPOINT=
ZK_FABRIC_ADMIN_TOKEN=
# Bucket name template; supports {slug} and {tenant_id}.
ZK_FABRIC_BUCKET_TEMPLATE=kapp-{slug}
