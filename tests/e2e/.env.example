# Mailosaur – required
MAILOSAUR_API_KEY=your-mailosaur-api-key
MAILOSAUR_SERVER_ID=your-server-id

# App / API
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:5173/api

# Auth – either provide a bearer token OR email+password
AUTH_TOKEN=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# .ovpn validation (TC036)
EXPECTED_OVPN_SERVER_HOST=
EXPECTED_OVPN_SERVER_PORT=1194
EXPECTED_OVPN_PROTO=udp

# Invitation link pattern (TC084) – regex
INVITE_LINK_PATTERN=install|setup|join|accept|invite
